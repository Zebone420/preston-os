[Unit]
Description=Preston AI OS Hermes observe-only (bounded)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Dedicated least-privilege Hermes identity (separate from the worker + owner).
User=preston-hermes
Group=preston-hermes
WorkingDirectory=/srv/preston-os/apps/dashboard
# Hermes-only env + token store (distinct from the worker's).
EnvironmentFile=/etc/preston/hermes.env
# Observe-only: reads state + records decisions/events. Never leases/executes.
# Requires hermes_mode=observe_only in system_controls (owner-set) to do work.
ExecStart=/usr/bin/node dist/os-runtime/bin.js hermes-loop --max 5
Restart=no
TimeoutStartSec=120
RuntimeMaxSec=300
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
# Same EROFS trap as the worker: the Hermes token store rotates atomically
# under /var/lib/preston/hermes, which ProtectSystem=strict otherwise seals.
ReadWritePaths=/var/lib/preston/hermes
# Creates/owns /var/log/preston (0755, user preston) and grants write access,
# so ProtectSystem=strict does not abort startup on a fresh host.
LogsDirectory=preston
StandardOutput=append:/var/log/preston/hermes.log
StandardError=append:/var/log/preston/hermes.log
# No [Install]: never auto-starts; the timer (owner-enabled) fires it.
